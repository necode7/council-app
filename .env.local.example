# ============================================================================
# SUPABASE - Database & Authentication
# ============================================================================
# These are your Supabase project credentials
# Get from: https://app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Service role key — bypasses RLS. Used ONLY by seed scripts, never in app code.
# Get from: Supabase Dashboard → Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ============================================================================
# OPENROUTER - Multi-Model AI API
# ============================================================================
# Used for council pipeline (advisors, chairman, clarifier, slugger)
# Get from: https://openrouter.ai/keys
# NEVER prefix with NEXT_PUBLIC_ — this is a server secret!
# callModel() in src/lib/ai/openrouter.ts uses this
OPENROUTER_API_KEY=sk-or-v1-...

# ============================================================================
# APP URL - Public URL of your application
# ============================================================================
# Used in:
# - OpenRouter HTTP-Referer header (required by their API)
# - Cashfree return_url (where user goes after payment)
# - Cashfree notify_url (where we receive payment webhooks)
# Example: http://localhost:3000 (dev) or https://council.example.com (prod)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================================
# POSTHOG - Product Analytics
# ============================================================================
# Public project key for client-side event tracking
# Get from: PostHog Project Settings -> Project API Key
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_project_key

# ============================================================================
# CASHFREE PAYMENT GATEWAY - Subscription Billing
# ============================================================================
# These are your Cashfree merchant credentials for accepting payments
# NEVER prefix with NEXT_PUBLIC_ — these are server secrets!
# Security: Only expose these in server-side code (/api routes)
#
# GET THESE CREDENTIALS:
# 1. Sign up at https://dashboard.cashfree.com
# 2. Go to Settings → API Keys
# 3. Copy Client ID, Client Secret, and Webhook Secret
#
# WHAT EACH DOES:
# - CASHFREE_CLIENT_ID: Identifies your merchant account to Cashfree
#   Used in: src/app/api/billing/checkout/route.ts (create orders)
#
# - CASHFREE_CLIENT_SECRET: Authenticates your API calls to Cashfree
#   Used in: src/app/api/billing/checkout/route.ts (create orders)
#   WARNING: Never expose this in frontend code
#
# - CASHFREE_WEBHOOK_SECRET: Verifies webhook authenticity
#   Used in: src/app/api/billing/webhook/route.ts (verify payment notifications)
#   IMPORTANT: Set this same secret in Cashfree Dashboard → Webhooks
#
# AFTER GETTING CREDENTIALS:
# Add webhook URL to Cashfree Dashboard → Webhooks → Add Endpoint:
# {NEXT_PUBLIC_APP_URL}/api/billing/webhook
# Make sure 'Signature Verification' is enabled
#
CASHFREE_CLIENT_ID=your-cashfree-client-id
CASHFREE_CLIENT_SECRET=your-cashfree-client-secret
CASHFREE_WEBHOOK_SECRET=your-cashfree-webhook-secret

# ============================================================================
# RESEND - Transactional Email
# ============================================================================
# Used to send welcome, council-complete, credits-low, and outcome-reminder emails
# Get from: https://resend.com/api-keys
# NEVER prefix with NEXT_PUBLIC_ — this is a server secret!
RESEND_API_KEY=re_...

# ============================================================================
# INTERNAL API KEY - Internal service-to-service auth
# ============================================================================
# Protects /api/email/send (and other internal endpoints) from public access
# Generate any long random string, e.g.: openssl rand -hex 32
INTERNAL_API_KEY=your-internal-api-key
